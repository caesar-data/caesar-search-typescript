          },
          "freshness_policy": {
            "additionalProperties": {},
            "description": "Optional freshness requirements for time-sensitive queries.",
            "type": "object"
          },
          "max_results": {
            "default": 10,
            "description": "Maximum number of ranked results to return.",
            "format": "int64",
            "maximum": 50,
            "minimum": 1,
            "type": "integer"
          },
          "mode": {
            "default": "standard",
            "description": "Retrieval budget and ranking mode.",
