          "503": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorEnvelope"
                }
              }
            },
            "description": "Search infrastructure unavailable."
          }
        },
        "summary": "Get a document",
        "tags": [
          "Documents"
        ],
        "x-audience": "public"
      }
    },
